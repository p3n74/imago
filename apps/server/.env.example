BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
# In dev, use http://localhost:3001 (Vite port)
CORS_ORIGIN=

DATABASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_PASSWORD=

PORT=

//  32 Characters
CHAT_ENCRYPTION_KEY=

# Path where user copies their photo folder for bulk import
PHOTOS_IMPORT_PATH=./import/photos

# Path for ephemeral transcoded video cache
VIDEO_CACHE_PATH=./storage/videos/tmp

# Delete cached transcoded videos older than this many days
VIDEO_CACHE_MAX_AGE_DAYS=7

# Best-effort max cache size in GB for transcoded videos
VIDEO_CACHE_MAX_SIZE_GB=20

# Cap concurrent ffmpeg transcodes to protect CPU
VIDEO_MAX_CONCURRENT_TRANSCODES=2

# Enable lightweight video performance logs
VIDEO_PERF_LOGS=false

# Pre-transcode newly imported videos into cache profile
VIDEO_PRETRANSCODE_ON_IMPORT=false
VIDEO_PRETRANSCODE_PROFILE=low
